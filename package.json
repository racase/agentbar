{
  "name": "agentbar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "agentbar": "bin/agentbar.cjs"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "vite build",
    "start": "node bin/agentbar.cjs",
    "package": "electron-builder --win nsis portable"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^39.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.1.12"
  },
  "devDependencies": {
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "io.github.agentbar",
    "productName": "AgentBar",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "bin/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
